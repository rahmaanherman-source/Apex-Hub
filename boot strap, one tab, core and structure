const BASE = import.meta.env.VITE_API_URL || 'http://localhost:8000/api/v1';
export async function fetchAPI(path: string) {
  const res = await fetch(`${BASE}${path}`);
  if (!res.ok) throw new Error(`API ${path} failed`);
  return res.json();
}
EOF

