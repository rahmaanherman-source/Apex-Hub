'use client'
import { useState } from 'react'
import ImageCanvas from '@/components/ImageCanvas'
import ModeSelector from '@/components/ModeSelector'
import OverlaySlider from '@/components/OverlaySlider'
import { api } from '@/lib/api'

export default function ForensicViewer() {
  const [original, setOriginal] = useState<string | null>(null)
  const [processed, setProcessed] = useState<string | null>(null)
  const [mode, setMode] = useState('liquid_glass_fusion')

  const handleFileUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0]
    if (!file) return
    const reader = new FileReader()
    reader.onload = () => setOriginal(reader.result as string)
    reader.readAsDataURL(file)

    const formData = new FormData()
    formData.append('file', file)
    const res = await api.upload('/vision/process', formData, { mode })
    setProcessed(res)
  }

  return (
    <div className="min-h-screen bg-gray-900 text-white p-6">
      <h1 className="text-3xl font-bold mb-6">APEX Vision Forensic Viewer</h1>
      <input type="file" onChange={handleFileUpload} accept="image/*" className="mb-4" />
      <ModeSelector current={mode} onChange={setMode} />
      <div className="grid grid-cols-2 gap-4 mt-6">
        <ImageCanvas title="Original" imageUrl={original} />
        <ImageCanvas title={`Processed (${mode})`} imageUrl={processed} />
      </div>
      <OverlaySlider originalUrl={original} processedUrl={processed} />
    </div>
  )
}
