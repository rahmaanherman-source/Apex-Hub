apps/backend/services/ai_supervisor.py (Real Azure + Qdrant)

```python
import asyncio, json, openai
from typing import Any, Dict, List
from redis import Redis
from qdrant_client import QdrantClient
from qdrant_client.models import Distance, VectorParams, PointStruct
from core.config import settings

class AISupervisor:
    def __init__(self):
        openai.api_key = settings.AZURE_OPENAI_API_KEY
        openai.api_base = settings.AZURE_OPENAI_ENDPOINT
        self.model = settings.AZURE_OPENAI_MODEL
        self.embedding_model = settings.AZURE_EMBEDDING_MODEL
        self.qdrant = QdrantClient(host=settings.QDRANT_HOST, port=settings.QDRANT_PORT)
        self.redis = Redis.from_url(settings.REDIS_URL)
        self._ensure_collection()

    def _ensure_collection(self):
        if not self.qdrant.collection_exists("knowledge_articles"):
            self.qdrant.create_collection(
                collection_name="knowledge_articles",
                vectors_config=VectorParams(size=1536, distance=Distance.COSINE)
            )

    def _embed(self, text: str) -> List[float]:
        resp = openai.Embedding.create(input=[text], engine=self.embedding_model)
        return resp['data'][0]['embedding']

    async def process_ticket(self, ticket_id: str, text: str) -> Dict[str, Any]:
        sentiment_task = asyncio.create_task(self._analyze_sentiment(text))
        intent_task = asyncio.create_task(self._detect_intent(text))
        kb_docs_task = asyncio.create_task(self._retrieve_kb_context(text))
        sentiment, intent, kb_docs = await asyncio.gather(sentiment_task, intent_task, kb_docs_task)
        confidence = self._calculate_confidence(sentiment, intent, kb_docs)
        draft = None
        escalate = False
        if confidence >= 0.85 and sentiment["score"] > -0.7:
            draft = self._generate_draft(text, kb_docs)
        else:
            escalate = True
        result = {
            "ticket_id": ticket_id,
            "sentiment": sentiment,
            "intent": intent,
            "retrieved_articles": kb_docs,
            "confidence": confidence,
            "draft_response": draft,
            "should_escalate": escalate
        }
        self.redis.setex(f"ai_telemetry:{ticket_id}", 3600, json.dumps(result))
        return result

    async def _analyze_sentiment(self, text: str) -> Dict:
        prompt = f"Analyze sentiment of this customer message. Return JSON with 'score' (float between -1 and 1) and 'label' (string: 'positive', 'neutral', 'negative').\nMessage: {text}\nJSON:"
        resp = openai.ChatCompletion.create(engine=self.model, messages=[{"role":"user","content":prompt}], temperature=0.1)
        try:
            return json.loads(resp.choices[0].message.content)
        except:
            return {"score": 0.0, "label": "neutral"}

    async def _detect_intent(self, text: str) -> str:
        prompt = f"Classify the intent of this customer message. Choose exactly one word from: billing, technical, general, sales, returns, other.\nMessage: {text}\nIntent:"
        resp = openai.ChatCompletion.create(engine=self.model, messages=[{"role":"user","content":prompt}], temperature=0.1, max_tokens=10)
        return resp.choices[0].message.content.strip().lower()

    async def _retrieve_kb_context(self, query: str) -> List[Dict]:
        vec = self._embed(query)
        hits = self.qdrant.search(collection_name="knowledge_articles", query_vector=vec, limit=3)
        return [
            {
                "article_id": hit.id,
                "title": hit.payload.get("title",""),
                "content": hit.payload.get("text",""),
                "score": hit.score
            }
            for hit in hits
        ]

    def _calculate_confidence(self, sentiment, intent, docs):
        if not docs:
            return 0.3
        top_score = max(d["score"] for d in docs)
        if sentiment["label"] == "negative":
            return min(top_score, 0.7)
        return top_score

    def _generate_draft(self, user_query, docs):
        articles = "\n".join([f"- {d['content'][:300]}" for d in docs])
        prompt = f"You are a helpful customer support assistant. Use the following knowledge base articles to answer the user's question. If the articles do not contain the answer, politely say so and suggest creating a support ticket.\n\nUser Query: {user_query}\n\nKnowledge Base:\n{articles}\n\nAnswer:"
        resp = openai.ChatCompletion.create(engine=self.model, messages=[{"role":"user","content":prompt}], temperature=0.3, max_tokens=300)
        return resp.choices[0].message.content
