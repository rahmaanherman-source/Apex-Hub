from fastapi import APIRouter, UploadFile, File, Query, HTTPException
from fastapi.responses import FileResponse
from core.clarity_engine import ClarityEngine
from core.modes import SpectralMode
from core.calibration import OpticalCalibrator
import cv2, tempfile, os, numpy as np

router = APIRouter()
engine = ClarityEngine(use_gpu=True)
calibrator = OpticalCalibrator()

@router.post("/calibrate/dark")
async def calibrate_dark(files: list[UploadFile] = File(...)):
    """Upload multiple dark frames for calibration."""
    frames = []
    for file in files:
        contents = await file.read()
        nparr = np.frombuffer(contents, np.uint8)
        frame = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
        frames.append(frame)
    dark = calibrator.capture_dark_frame(frames)
    cv2.imwrite("dark_frame.png", dark)
    return {"message": "Dark frame captured", "shape": dark.shape}

@router.post("/calibrate/flat")
async def calibrate_flat(files: list[UploadFile] = File(...)):
    """Upload flat-field frames."""
    # similar to above
    pass

@router.post("/calibrate/color")
async def calibrate_color(ref_colors: list, cap_colors: list):
    """Submit reference and captured color values."""
    matrix = calibrator.calibrate_color(ref_colors, cap_colors)
    return {"matrix": matrix.tolist()}

@router.post("/process")
async def process_image(
    file: UploadFile = File(...),
    mode: str = Query("liquid_glass")
):
    """Process an image with the selected clarity mode."""
    try:
        spectral_mode = SpectralMode.from_string(mode)
    except KeyError:
        raise HTTPException(400, "Invalid mode")

    contents = await file.read()
    nparr = np.frombuffer(contents, np.uint8)
    img = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

    # Apply calibration if available
    img = calibrator.apply_calibration(img)

    result = engine.process_frame(img, spectral_mode)
    result_bgr = cv2.cvtColor(result, cv2.COLOR_RGB2BGR)
    _, temp_path = tempfile.mkstemp(suffix=".png")
    cv2.imwrite(temp_path, result_bgr)
    return FileResponse(temp_path, media_type="image/png")

@router.post("/process-video")
async def process_video_endpoint(
    file: UploadFile = File(...),
