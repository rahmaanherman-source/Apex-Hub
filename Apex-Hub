3. Optical Calibration Pipeline

backend/core/calibration.py

```python
import numpy as np
import cv2
from typing import Tuple

class OpticalCalibrator:
    def __init__(self):
        self.dark_frame = None
        self.flat_field = None
        self.color_matrix = None

    def capture_dark_frame(self, frames: list) -> np.ndarray:
        """Average multiple dark frames (lens cap on)."""
        self.dark_frame = np.mean(frames, axis=0).astype(np.float32)
        return self.dark_frame

    def capture_flat_field(self, frames: list) -> np.ndarray:
        """Capture flat-field frames (uniform illumination)."""
        avg = np.mean(frames, axis=0).astype(np.float32)
        # Normalize to unity
        self.flat_field = avg / np.mean(avg)
        return self.flat_field

    def calibrate_color(self, reference_colors: list, captured_colors: list) -> np.ndarray:
        """Compute a 3x3 color correction matrix."""
        # reference/captured: Nx3 arrays of RGB values
        ref = np.array(reference_colors)
        cap = np.array(captured_colors)
        # Solve for matrix M: cap * M = ref
        M, _, _, _ = np.linalg.lstsq(cap, ref, rcond=None)
        self.color_matrix = M.T  # 3x3
        return self.color_matrix

    def apply_calibration(self, image: np.ndarray) -> np.ndarray:
        """Apply dark, flat, and color calibration."""
        if self.dark_frame is not None:
            image = cv2.subtract(image, self.dark_frame)
        if self.flat_field is not None:
            image = cv2.divide(image, self.flat_field + 1e-6)
        if self.color_matrix is not None:
            # Reshape to Nx3, apply matrix, reshape back
            h, w = image.shape[:2]
            pixels = image.reshape(-1, 3).astype(np.float32)
            corrected = np.dot(pixels, self.color_matrix.T)
            image = corrected.reshape(h, w, 3).clip(0, 255).astype(np.uint8)
        return image
