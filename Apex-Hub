async def update_health_after_purchase(db: AsyncSession, customer_id: uuid.UUID):
    stmt = select(Customer).where(Customer.id == customer_id)
    res = await db.execute(stmt)
    customer = res.scalar()
    if not customer:
        return

    base_score = 50.0
    ltv = float(customer.lifetime_value or 0.0)
    rev_score = min(ltv / 1000.0, 1.0) * 30.0

    total_orders = customer.total_orders or 0
    freq_score = min(total_orders / 5.0, 1.0) * 20.0

    last_order = customer.last_order_at
    days_since = (datetime.now(timezone.utc) - last_order).days if last_order else 365
    recency_score = max(0.0, 10.0 - (days_since / 30.0))

    aov = float(customer.average_order_value or 0.0)
    aov_score = min(aov / 200.0, 1.0) * 10.0

    new_health = min(base_score + rev_score + freq_score + recency_score + aov_score, 100.0)
    customer.health_score = new_health
    await db.flush()

