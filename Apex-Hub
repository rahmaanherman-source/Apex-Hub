2. Core Clarity Engine (CPU + GPU)

backend/core/clarity_engine.py

```python
import cv2
import numpy as np
from typing import List, Dict, Optional
from .gpu_kernels import GPUAccelerator
from .modes import SpectralMode, apply_mode

class ClarityEngine:
    def __init__(self, use_gpu: bool = True):
        self.gpu = GPUAccelerator() if use_gpu else None

    def process_frame(
        self,
        frame: np.ndarray,
        mode: SpectralMode,
        params: Optional[Dict] = None
    ) -> np.ndarray:
        """Process a single frame through the selected clarity mode."""
        # 1. Normalize to float32 linear
        if frame.dtype != np.float32:
            frame = frame.astype(np.float32) / 255.0

        # 2. Apply spectral decomposition
        if self.gpu:
            spectral = self.gpu.decompose(frame, mode)
        else:
            spectral = self._cpu_decompose(frame, mode)

        # 3. Enhancement stack
        enhanced = self._enhance(spectral, mode)

        # 4. Fusion
        output = self._fuse(enhanced, mode)

        # 5. Temporal stabilization (if video)
        # (implemented via motion-compensated buffer)

        return (output * 255).astype(np.uint8)  # back to 8-bit

    def _cpu_decompose(self, frame: np.ndarray, mode: SpectralMode) -> np.ndarray:
        """Fallback CPU decomposition."""
        # Extract channels based on mode
        if mode == SpectralMode.ALS_UV:
            # Simulate UV via weighted subtraction
            gray = cv2.cvtColor(frame, cv2.COLOR_RGB2GRAY)
            return cv2.applyColorMap(gray, cv2.COLORMAP_BONE)
        elif mode == SpectralMode.NIR:
            # Near-infrared simulation (red channel emphasis)
            r, g, b = cv2.split(frame)
            nir = (r * 0.8 + g * 0.2).astype(np.float32)
            return cv2.merge([nir, nir, nir])
        elif mode == SpectralMode.RAMAN:
            # High-pass edge map
            gray = cv2.cvtColor(frame, cv2.COLOR_RGB2GRAY)
            edges = cv2.Sobel(gray, cv2.CV_32F, 1, 1)
            return cv2.normalize(edges, None, 0, 1, cv2.NORM_MINMAX)
        elif mode == SpectralMode.CYAN:
            # Cyan channel = green + blue, reduced red
            r, g, b = cv2.split(frame)
            cyan = (g * 0.7 + b * 0.3).astype(np.float32)
            return cv2.merge([np.zeros_like(cyan), cyan, cyan])
        elif mode == SpectralMode.LIQUID_GLASS:
            # Multi-band fusion with micro-contrast
            gray = cv2.cvtColor(frame, cv2.COLOR_RGB2GRAY)
            clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))
            return clahe.apply((gray * 255).astype(np.uint8)).astype(np.float32) / 255.0
        else:
            return frame

    def _enhance(self, img: np.ndarray, mode: SpectralMode) -> np.ndarray:
        """Apply enhancement stack: CLAHE, denoise, sharpen."""
        # Bilateral denoise
        denoised = cv2.bilateralFilter(img, 9, 75, 75)

        # CLAHE contrast
        if len(denoised.shape) == 3:
            lab = cv2.cvtColor(denoised, cv2.COLOR_RGB2LAB)
            l, a, b = cv2.split(lab)
            clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))
            l = clahe.apply(l.astype(np.uint8))
            denoised = cv2.merge([l, a, b])
            denoised = cv2.cvtColor(denoised, cv2.COLOR_LAB2RGB)
        else:
            denoised = cv2.createCLAHE(clipLimit=2.0).apply(denoised.astype(np.uint8))

        # Sharpening
        kernel = np.array([[0, -1, 0], [-1, 5, -1], [0, -1, 0]])
        sharpened = cv2.filter2D(denoised, -1, kernel)
        return sharpened

    def _fuse(self, img: np.ndarray, mode: SpectralMode) -> np.ndarray:
        """Apply mode-specific fusion."""
        if mode == SpectralMode.LIQUID_GLASS:
            # Weighted combination of original + enhanced
            original = self.current_frame  # need to store original
            return cv2.addWeighted(img, 0.7, original, 0.3, 0)
        return img

    def process_video(self, input_path: str, output_path: str, mode: SpectralMode):
        """Process a video file."""
        cap = cv2.VideoCapture(input_path)
        fourcc = cv2.VideoWriter_fourcc(*'mp4v')
        out = cv2.VideoWriter(output_path, fourcc, cap.get(cv2.CAP_PROP_FPS),
                              (int(cap.get(3)), int(cap.get(4))))
        while True:
            ret, frame = cap.read()
            if not ret:
                break
            processed = self.process_frame(frame, mode)
            out.write(processed)
        cap.release()
        out.release()
