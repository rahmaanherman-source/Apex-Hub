import cupy as cp
import cupyx.scipy.ndimage

class GPUAccelerator:
    def decompose(self, frame: np.ndarray, mode: SpectralMode) -> np.ndarray:
        gpu = cp.asarray(frame, dtype=cp.float32)
        if mode == SpectralMode.RAMAN_SIM:
            gray = cp.dot(gpu[..., :3], cp.array([0.299, 0.587, 0.114]))
            sobel_x = cupyx.scipy.ndimage.sobel(gray, axis=1)
            sobel_y = cupyx.scipy.ndimage.sobel(gray, axis=0)
            edges = cp.sqrt(sobel_x**2 + sobel_y**2)
            return cp.asnumpy(edges)
        elif mode == SpectralMode.NIR_SIM:
            r, g = gpu[:,:,0], gpu[:,:,1]
            nir = r * 0.8 + g * 0.2
            return cp.asnumpy(cp.stack([nir, nir, nir], axis=2))
        # ... other modes
        return frame
