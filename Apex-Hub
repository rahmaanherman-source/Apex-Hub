    def __init__(self, use_gpu: bool = True):
        self.gpu = GPUAccelerator() if use_gpu else None

    def process_frame(self, frame: np.ndarray, mode: SpectralMode, params: Optional[Dict] = None) -> np.ndarray:
        """Process a single frame. Original frame is explicitly preserved."""
        original = frame.copy().astype(np.float32) / 255.0
        decomposed = self._decompose(original, mode)
        enhanced = self._enhance(decomposed, mode)
        if mode == SpectralMode.LIQUID_GLASS_FUSION:
            fused = cv2.addWeighted(enhanced, 0.7, original, 0.3, 0)
            return to_output(fused)
        return to_output(enhanced)

    def _decompose(self, img: np.ndarray, mode: SpectralMode) -> np.ndarray:
        if self.gpu:
            return self.gpu.decompose(img, mode)
        return self._cpu_decompose(img, mode)

    def _cpu_decompose(self, img: np.ndarray, mode: SpectralMode) -> np.ndarray:
        # ... (same as before but using to_internal already)
        pass

    def _enhance(self, img: np.ndarray, mode: SpectralMode) -> np.ndarray:
        # Bilateral + CLAHE (now safe with float32)
        denoised = cv2.bilateralFilter(img, 9, 75, 75)
        if len(denoised.shape) == 3:
            lab = cv2.cvtColor(denoised, cv2.COLOR_RGB2LAB)
            l, a, b = cv2.split(lab)
            clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))
            l = clahe.apply((l * 255).astype(np.uint8)).astype(np.float32) / 255.0
            denoised = cv2.merge([l, a, b])
            denoised = cv2.cvtColor(denoised, cv2.COLOR_LAB2RGB)
        else:
            denoised = cv2.createCLAHE(clipLimit=2.0).apply(
                (denoised * 255).astype(np.uint8)
            ).astype(np.float32) / 255.0
        kernel = np.array([[0, -1, 0], [-1, 5, -1], [0, -1, 0]])
        return cv2.filter2D(denoised, -1, kernel)

    # process_video remains but now uses async generator
