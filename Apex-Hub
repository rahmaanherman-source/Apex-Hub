from fastapi import APIRouter, UploadFile, File, Query
from fastapi.responses import StreamingResponse
from core.clarity_engine import ClarityEngine
from core.modes import SpectralMode
from core.calibration import OpticalCalibrator
import cv2, io, numpy as np

router = APIRouter()
engine = ClarityEngine(use_gpu=True)

@router.post("/process")
async def process_image(file: UploadFile = File(...), mode: str = Query("liquid_glass_fusion")):
    contents = await file.read()
    nparr = np.frombuffer(contents, np.uint8)
    img = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

    mode_enum = SpectralMode[mode.upper()]
    result = engine.process_frame(img, mode_enum)
    _, encoded = cv2.imencode('.png', cv2.cvtColor(result, cv2.COLOR_RGB2BGR))
    return StreamingResponse(io.BytesIO(encoded.tobytes()), media_type="image/png")
