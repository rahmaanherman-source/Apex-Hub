```python
import numpy as np
try:
    import cupy as cp
    HAS_GPU = True
except ImportError:
    HAS_GPU = False

from .modes import SpectralMode

class GPUAccelerator:
    def __init__(self):
        if not HAS_GPU:
            raise RuntimeError("CuPy not installed. Cannot use GPU acceleration.")
        self.stream = cp.cuda.Stream()

    def decompose(self, frame: np.ndarray, mode: SpectralMode) -> np.ndarray:
        """GPU-accelerated spectral decomposition."""
        gpu_frame = cp.asarray(frame, dtype=cp.float32)
        with self.stream:
            if mode == SpectralMode.NIR:
                # Red channel emphasis
                r = gpu_frame[:, :, 0]
                g = gpu_frame[:, :, 1]
                nir = r * 0.8 + g * 0.2
                return cp.asnumpy(cp.stack([nir, nir, nir], axis=2))
            elif mode == SpectralMode.RAMAN:
                gray = cp.dot(gpu_frame[..., :3], cp.array([0.299, 0.587, 0.114]))
                sobel_x = cp.zeros_like(gray)
                cp.ElementwiseKernel(
                    'float64[:,:], float64[:,:]',
                    'float64[:,:]',
                    '''
                    if (i > 0 && i < _ind.size(0)-1 && j > 0 && j < _ind.size(1)-1) {
                        _preprocessed[i, j] = 0.125 * (_preprocessed[i-1,j-1] - _preprocessed[i+1,j-1])
                                               + 0.25 * (_preprocessed[i-1,j] - _preprocessed[i+1,j])
                                               + 0.125 * (_preprocessed[i-1,j+1] - _preprocessed[i+1,j+1]);
                    }
                    ''',
                    'sobel_x'
                )(gray, sobel_x)
                return cp.asnumpy(sobel_x)
            # ... other modes implemented similarly
            else:
                return frame  # fallback to CPU

    def enhance_clahe(self, img: np.ndarray) -> np.ndarray:
        """GPU-based CLAHE using CuPy (simplified for demo; full implementation would use custom kernel)."""
        # Use OpenCV's CLAHE which is already optimized, or custom kernel
        import cv2
        return cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8)).apply(img)
