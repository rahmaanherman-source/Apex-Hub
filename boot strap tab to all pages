            <CartesianGrid strokeDasharray="3 3" stroke="#1E2A5E" />
            <XAxis dataKey="date" stroke="#A8B2D1" />
            <YAxis stroke="#A8B2D1" />
            <Tooltip />
            <Line type="monotone" dataKey="revenue" stroke="#D4AF37" strokeWidth={2} />
          </LineChart>
        </ResponsiveContainer>
      </div>
    </div>
  )
}
EOF

