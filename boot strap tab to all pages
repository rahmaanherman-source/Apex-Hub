#!/usr/bin/env bash
set -euo pipefail
PROJECT="Apex-Hub"
mkdir -p $PROJECT
cd $PROJECT

write_file() { mkdir -p "$(dirname "$1")"; cat > "$1"; }

write_file src/pages/Dashboard.tsx <<'EOF'
import { useEffect, useState } from 'react'
import { fetchAPI } from '../utils/api'
import MetricsCard from '../components/MetricsCard'

export default function Dashboard() {
  const [stats, setStats] = useState<any>(null)
  useEffect(() => { fetchAPI('/dashboard').then(setStats) }, [])
  return (
    <div>
      <h1 className="text-2xl font-display text-gold mb-6">Dashboard</h1>
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <MetricsCard label="Revenue (MRR)" value={stats?.mrr ?? '…'} />
        <MetricsCard label="Orders" value={stats?.orders ?? '…'} />
        <MetricsCard label="Customers" value={stats?.customers ?? '…'} />
        <MetricsCard label="Trust Score" value={stats?.trustScore ?? '…'} />
      </div>
    </div>
  )
}
EOF

